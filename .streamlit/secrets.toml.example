# Copy this file to .streamlit/secrets.toml and fill in your values

# ─── LLM Settings ─────────────────────────────────────────────────────────────
llm_provider = "Gemini (free API)"
gemini_api_key = "YOUR_GEMINI_API_KEY"
gemini_model = "gemini-2.5-flash"

# HuggingFace (only needed if using HuggingFace provider)
hf_token = ""
hf_model = "mistralai/Mistral-7B-Instruct-v0.3"

# Ollama (only needed if using Ollama provider)
ollama_url = "http://localhost:11434"
ollama_model = "llama3"

# ─── Database Settings (optional) ─────────────────────────────────────────────
db_host = "localhost"
db_port = 5432
db_name = ""
db_user = ""
db_password = ""
db_schema = "public"
